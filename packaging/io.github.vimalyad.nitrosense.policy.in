<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE policyconfig PUBLIC "-//freedesktop//DTD PolicyKit Policy Configuration 1.0//EN"
  "http://www.freedesktop.org/standards/PolicyKit/1/policyconfig.dtd">
<policyconfig>
  <vendor>NitroSense Linux</vendor>
  <vendor_url>https://github.com/vimalyad/nitrosense</vendor_url>

  <action id="io.github.vimalyad.nitrosense.fan-control">
    <description>Control Acer Nitro fan speeds</description>
    <message>Authentication is required to control Acer Nitro fan speeds</message>
    <defaults>
      <allow_any>no</allow_any>
      <allow_inactive>no</allow_inactive>
      <allow_active>auth_admin_keep</allow_active>
    </defaults>
    <annotate key="org.freedesktop.policykit.exec.path">@NITROSENSE_EXEC@</annotate>
    <annotate key="org.freedesktop.policykit.exec.argv1">--fan-helper</annotate>
  </action>
</policyconfig>
